# Normal builds always start in production. Configure production endpoints for packaged builds.
VITE_MEMORYBREAD_PRODUCTION_ADMIN_API_BASE_URL=http://127.0.0.1:8080
VITE_MEMORYBREAD_PRODUCTION_GATEWAY_API_BASE_URL=http://127.0.0.1:8090

# Debug mode may select staging. Keep staging on dedicated service instances/ports.
VITE_MEMORYBREAD_STAGING_ADMIN_API_BASE_URL=http://127.0.0.1:18080
VITE_MEMORYBREAD_STAGING_GATEWAY_API_BASE_URL=http://127.0.0.1:18090

# Startup debug mode is session-scoped. Normal launches ignore persisted debug/staging state.
VITE_MEMORYBREAD_DEBUG_MODE=false
